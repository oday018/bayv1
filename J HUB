-- [[ BAT REVENGE: When hit with bat, automatically swing bat back ]] --
local BatRevengeEnabled = false
local lastBatRevengeTime = 0

local function findCombatAttacker(maxDistance)
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    local nearestChar = nil
    local nearestDistance = maxDistance or 22

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local targetChar = plr.Character
            local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
            local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
            if targetHum and targetHum.Health > 0 and targetRoot then
                local hasCombatTool = false
                for _, item in ipairs(targetChar:GetChildren()) do
                    if item:IsA("Tool") and (item.Name == "Bat" or item.Name == "Medusa's Head") then
                        hasCombatTool = true
                        break
                    end
                end
                if hasCombatTool then
                    local distance = (targetRoot.Position - myRoot.Position).Magnitude
                    if distance <= nearestDistance then
                        nearestDistance = distance
                        nearestChar = targetChar
                    end
                end
            end
        end
    end

    return nearestChar
end

local function engageAutoLock(targetChar)
    if targetChar and targetChar.Parent then
        lockedTarget = targetChar
    end
    if not AutoLockOnEnabled and not SETTINGS.LOCK_ENABLED then return end

    SETTINGS.LOCK_ENABLED = true
    if setLockState then
        setLockState(true)
    else
        startLockOn()
        startAutoBat()
    end
end

local function setupBatRevenge()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    hum.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Physics or newState == Enum.HumanoidStateType.FallingDown or newState == Enum.HumanoidStateType.Ragdoll then
            local attacker = findCombatAttacker(22)

            if BatRevengeEnabled and tick() - lastBatRevengeTime >= 0.5 then
                lastBatRevengeTime = tick()
                task.spawn(function()
                    local myChar = LocalPlayer.Character
                    if not myChar then return end
                    local hum2 = myChar:FindFirstChildOfClass("Humanoid")
                    if not hum2 then return end

                    local bat = nil
                    for _, tool in ipairs(myChar:GetChildren()) do
                        if tool:IsA("Tool") and tool.Name == "Bat" then bat = tool break end
                    end
                    if not bat then
                        local bp = LocalPlayer:FindFirstChild("Backpack")
                        if bp then
                            for _, tool in ipairs(bp:GetChildren()) do
                                if tool:IsA("Tool") and tool.Name == "Bat" then bat = tool break end
                            end
                        end
                    end

                    if attacker then
                        lockedTarget = attacker
                    end

                    if bat then
                        if bat.Parent ~= myChar then
                            hum2:EquipTool(bat)
                        end
                        task.wait(0.03)
                        pcall(function() bat:Activate() end)
                        task.wait(0.05)
                        pcall(function() bat:Activate() end)
                    end
                end)
            end

            if AutoLockOnEnabled or SETTINGS.LOCK_ENABLED then
                task.spawn(function()
                    task.wait(attacker and 0.02 or 0.05)
                    engageAutoLock(attacker)
                end)
            end
        end
    end)
end


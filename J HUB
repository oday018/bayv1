local xrayOriginals = {}
local function enableXray()
    xrayOriginals = {}
    pcall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Anchored
                and (obj.Name:lower():find("base") or (obj.Parent and obj.Parent.Name:lower():find("base"))) then
                xrayOriginals[obj] = obj.LocalTransparencyModifier
                obj.LocalTransparencyModifier = 0.88
            end
        end
    end)
end

local function disableXray()
    for part, val in pairs(xrayOriginals) do
        if part and part.Parent then part.LocalTransparencyModifier = val end
    end
    xrayOriginals = {}
end

-- [[ LOW GRAVITY ]] --
local EGO_LOW_GRAV_ON = false
local EGO_GRAV_PERCENT = 70
local EGO_HOP_POWER = 35
local normalGravity = workspace.Gravity
local lowGravConn_ego = nil

local function applyLowGravity()
    if not EGO_LOW_GRAV_ON then
        workspace.Gravity = normalGravity
        if lowGravConn_ego then lowGravConn_ego:Disconnect(); lowGravConn_ego = nil end
        return
    end
    workspace.Gravity = normalGravity * (EGO_GRAV_PERCENT / 100)
    if lowGravConn_ego then lowGravConn_ego:Disconnect() end
    lowGravConn_ego = RunService.Heartbeat:Connect(function()
        if not EGO_LOW_GRAV_ON then
            workspace.Gravity = normalGravity
            lowGravConn_ego:Disconnect(); lowGravConn_ego = nil; return
        end
        workspace.Gravity = normalGravity * (EGO_GRAV_PERCENT / 100)
        local char = LocalPlayer.Character; if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        if hrp.AssemblyLinearVelocity.Y < -EGO_HOP_POWER then
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, -EGO_HOP_POWER, hrp.AssemblyLinearVelocity.Z)
        end
    end)
end

-- [[ DODGE ]] --
local EGO_DODGE_ON = false
local EGO_DODGE_HEIGHT = 7
local dodgeConn_ego = nil

local function startDodge()
    if dodgeConn_ego then dodgeConn_ego:Disconnect() end
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y + EGO_DODGE_HEIGHT, hrp.Position.Z)
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
        end
    end
    dodgeConn_ego = RunService.Heartbeat:Connect(function()
        if not EGO_DODGE_ON then dodgeConn_ego:Disconnect(); dodgeConn_ego = nil; return end
        local c = LocalPlayer.Character; if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart"); if not h then return end
        h.AssemblyLinearVelocity = Vector3.new(h.AssemblyLinearVelocity.X, 0, h.AssemblyLinearVelocity.Z)
    end)
end

local function stopDodge()
    if dodgeConn_ego then dodgeConn_ego:Disconnect(); dodgeConn_ego = nil end
end

-- [[ HARD HIT ]] --
local EGO_HARDHIT_ON = false
local EGO_HARDHIT_RADIUS = 10
local hhRing_ego = nil

local function showHardHitRing()
    local char = LocalPlayer.Character; if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    if hhRing_ego and hhRing_ego.Parent then return end
    local r = EGO_HARDHIT_RADIUS
    local cyl = Instance.new("CylinderHandleAdornment")
    cyl.Name = "JHubHHRing"; cyl.Adornee = hrp
    cyl.Color3 = Color3.fromRGB(220, 30, 30); cyl.AlwaysOnTop = true; cyl.Transparency = 0
    cyl.Radius = r; cyl.InnerRadius = r - 0.3; cyl.Height = 0.15
    cyl.CFrame = CFrame.new(0, -3, 0)
    cyl.Parent = hrp
    hhRing_ego = cyl
end

local function hideHardHitRing()
    if hhRing_ego then hhRing_ego:Destroy(); hhRing_ego = nil end
end

RunService.Heartbeat:Connect(function()
    if not EGO_HARDHIT_ON then
        if hhRing_ego then hideHardHitRing() end
        return end
    local char = LocalPlayer.Character; if not char then return end
    if not char:FindFirstChild("HumanoidRootPart") then return end
    if not hhRing_ego or not hhRing_ego.Parent then showHardHitRing() end
    if hhRing_ego then
        hhRing_ego.Radius = EGO_HARDHIT_RADIUS
        hhRing_ego.InnerRadius = EGO_HARDHIT_RADIUS - 0.3
    end
end)

-- [[ JUMP BOOST ]] --
local EGO_JUMP_BOOST_ON = false
local EGO_JUMP_POWER = 50

RunService.Heartbeat:Connect(function()

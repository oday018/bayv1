local function MakeHUDButton(name, label, onToggle)
    local btn = Instance.new("TextButton", HUDScreen)
    btn.Size = UDim2.new(0, 130, 0, 44)
    btn.Position = resolvePosition(name)
    btn.BackgroundColor3 = Color3.fromRGB(10, 14, 32)
    btn.BackgroundTransparency = 0.65
    btn.BorderSizePixel = 0
    local bindName = BUTTON_TO_BIND[name]
    btn.Text = formatButtonText(label, bindName, false)
    btn.TextColor3 = Color3.fromRGB(200, 215, 225)
    btn.Font = Enum.Font.FredokaOne
    btn.TextSize = 12
    btn.TextStrokeTransparency = 0.3
    btn.TextStrokeColor3 = Color3.fromRGB(14, 18, 38)
    btn.AutoButtonColor = false
    btn.ZIndex = 5
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    AddOutline(btn)
    allButtons[name] = btn
    local active = false

    local borderAnimId = 0

    local function animateBorder(stroke, isOn)
        borderAnimId = borderAnimId + 1
        local animId = borderAnimId
        if isOn then
            stroke.Thickness = 2
            task.spawn(function()
                while btn and btn.Parent and active and animId == borderAnimId do
                    TweenService:Create(stroke, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                        Color = Color3.fromRGB(255, 60, 60), Thickness = 2
                    }):Play()
                    task.wait(0.5)
                    if not btn or not btn.Parent or not active or animId ~= borderAnimId then break end
                    TweenService:Create(stroke, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                        Color = Color3.fromRGB(255, 255, 255), Thickness = 2
                    }):Play()
                    task.wait(0.5)
                end
                if stroke and stroke.Parent and (not active or animId ~= borderAnimId) then
                    stroke.Color = Color3.fromRGB(30, 120, 180)
                    stroke.Thickness = 1.5
                end
            end)
        else
            stroke.Color = Color3.fromRGB(30, 120, 180)
            stroke.Thickness = 1.5
        end
    end

    local btnStroke = nil
    for _, ch in ipairs(btn:GetChildren()) do
        if ch:IsA("UIStroke") then btnStroke = ch break end
    end

    local function setState(state)
        active = state
        btn.Text = formatButtonText(label, bindName, state)
        btn.BackgroundColor3 = state and Color3.fromRGB(200, 30, 30) or Color3.fromRGB(10, 14, 32)
        btn.BackgroundTransparency = state and 0.25 or 0.65
        btn.TextColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 215, 225)
        if btnStroke then animateBorder(btnStroke, state) end
    end

    MakeDraggable(btn, function()
        active = not active
        onToggle(active)
        setState(active)
    end)

    return btn, setState
end

